# Environment variables for Dropper Clicker Mobile App

# API Server Configuration
# The base URL of the API server. Used for cloud saves, leaderboards, and other backend features.
# Default: http://localhost:8000 (if not set, uses this fallback)
# Example: https://api.dropper-clicker.com
# EXPO_PUBLIC_DOMAIN=http://localhost:8000

# Firebase Configuration (for future use with authentication)
# When adding Firebase authentication, add these variables:
# FIREBASE_API_KEY=your-firebase-api-key
# FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# FIREBASE_MESSAGING_SENDER_ID=your-sender-id
# FIREBASE_APP_ID=your-app-id
